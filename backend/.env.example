# Server configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL container matching docker-compose.yml)
DATABASE_URL=postgresql://lms_user:lms_password@localhost:5432/lms_db?schema=public

# JWT Security
JWT_ACCESS_SECRET=your_short_term_jwt_access_secret_should_be_long_and_secure
JWT_REFRESH_SECRET=your_long_term_jwt_refresh_secret_should_be_long_and_secure

# Cloudinary Uploads (Optional: if empty, files will fallback to local storage /backend/uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email SMTP Setup (Nodemailer, can use Mailtrap or Gmail)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
EMAIL_FROM=noreply@lms-platform.com
