datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String           @id @default(uuid())
  name          String
  email         String           @unique
  password      String
  role          String           // ADMIN, DOCTOR, TA, STUDENT
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  profilePhoto  String?
  resetToken    String?
  resetTokenExpires DateTime?
  interests     String?
  
  // Relations
  courses       Course[]         @relation("DoctorCourses")
  enrollments   Enrollment[]
  teachingJobs  CourseTA[]
  submissions   Submission[]
  attempts      QuizAttempt[]
  notifications Notification[]
  watched       WatchedLecture[]
  attendances   Attendance[]
  comments          Comment[]
  announcements     Announcement[]
  publishedLectures Lecture[]
  posts             Post[]
  likedPosts        Post[]           @relation("UserLikesPost")
  savedPosts        Post[]           @relation("UserSavedPosts")
  sentEmails        Email[]          @relation("SentEmails")
  receivedEmails    Email[]          @relation("ReceivedEmails")
  studentTickets    SupportTicket[]  @relation("StudentTickets")
  assignedTickets   SupportTicket[]  @relation("AssignedTickets")
  ticketMessages    TicketMessage[]
  teamMemberships   TeamMember[]
  ownedProjects     WorkspaceProject[]
  internshipApps    InternshipApplication[]
}

model Course {
  id                 String              @id @default(uuid())
  title              String
  description        String
  code               String              @unique
  doctorId           String
  doctor             User                @relation("DoctorCourses", fields: [doctorId], references: [id])
  isPublished        Boolean             @default(false)
  isPaid             Boolean             @default(false)
  price              Float               @default(0.0)
  createdAt          DateTime            @default(now())

  // Relations
  enrollments        Enrollment[]
  tas                CourseTA[]
  lectures           Lecture[]
  assignments        Assignment[]
  quizzes            Quiz[]
  attendances        Attendance[]
  meetings           Meeting[]
  attendanceSessions AttendanceSession[]
  announcements      Announcement[]
}

model Enrollment {
  id         String   @id @default(uuid())
  studentId  String
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  @@unique([studentId, courseId])
}

model CourseTA {
  id       String @id @default(uuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId   String
  ta       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

model Lecture {
  id            String           @id @default(uuid())
  title         String
  courseId      String
  course        Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  weekNumber    Int
  fileUrl       String
  fileType      String           // VIDEO, PDF, SLIDES, OTHER
  allowDownload Boolean          @default(true)
  createdAt     DateTime         @default(now())
  publisherId   String?
  publisher     User?            @relation(fields: [publisherId], references: [id])

  // Relations
  watchedBy     WatchedLecture[]
  comments      Comment[]
}

model WatchedLecture {
  id        String   @id @default(uuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lectureId String
  lecture   Lecture  @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  watchedAt DateTime @default(now())

  @@unique([studentId, lectureId])
}

model Assignment {
  id          String       @id @default(uuid())
  title       String
  description String       // Rich text (HTML)
  courseId    String
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  deadline    DateTime
  maxScore    Int          @default(100)
  createdAt   DateTime     @default(now())
  fileUrl     String?
  
  // Relations
  submissions Submission[]
}

model Submission {
  id            String     @id @default(uuid())
  assignmentId  String
  assignment    Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId     String
  student       User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fileUrl       String
  submittedAt   DateTime   @default(now())
  isLate        Boolean    @default(false)
  grade         Float?
  feedback      String?
  gradedBy      String?    // User ID of the Doctor/TA who graded
  isTaGraded    Boolean    @default(false)
  taGradeReview Boolean    @default(false) // True if doctor approved TA grade

  @@unique([assignmentId, studentId])
}

model Quiz {
  id               String        @id @default(uuid())
  title            String
  courseId         String
  course           Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  timeLimit        Int           // in minutes
  maxAttempts      Int           @default(1)
  shuffleQuestions Boolean       @default(false)
  showResultsAfter String        @default("IMMEDIATE") // IMMEDIATE, AFTER_DEADLINE
  createdAt        DateTime      @default(now())
  fileUrl          String?
  
  // Relations
  questions        Question[]
  attempts         QuizAttempt[]
}

model Question {
  id            String   @id @default(uuid())
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text          String
  type          String   // MCQ, TRUE_FALSE, SHORT_ANSWER
  options       String   // JSON stringified array of options
  correctAnswer String
  points        Int      @default(1)
}

model QuizAttempt {
  id          String    @id @default(uuid())
  quizId      String
  quiz        Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentId   String
  student     User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers     String    // JSON string of answers map (questionId -> answer)
  score       Float?
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  tabSwitches Int       @default(0)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Attendance {
  id        String   @id @default(uuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      String
  status    String
  createdAt DateTime @default(now())

  @@unique([courseId, studentId, date])
}

model Meeting {
  id        String           @id @default(uuid())
  title     String
  courseId  String
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  hostId    String
  hostName  String
  hostRole  String
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  messages  MeetingMessage[]
}

model MeetingMessage {
  id          String   @id @default(uuid())
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  senderId    String
  senderName  String
  senderRole  String
  message     String
  createdAt   DateTime @default(now())
}

model AttendanceSession {
  id        String   @id @default(uuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  date      String
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Announcement {
  id            String    @id @default(uuid())
  courseId      String
  course        Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  content       String
  publisherId   String
  publisher     User      @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  comments      Comment[]
}

model Comment {
  id             String        @id @default(uuid())
  content        String
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  lectureId      String?
  lecture        Lecture?      @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  announcementId String?
  announcement   Announcement? @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  isPrivate      Boolean       @default(false)
  parentId       String?
  parent         Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies        Comment[]     @relation("CommentReplies")
  postId         String?
  post           Post?         @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Post {
  id         String      @id @default(uuid())
  content    String
  imageUrl   String?
  eventTitle String?
  eventDate  DateTime?
  authorId   String
  author     User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())
  likes      User[]      @relation("UserLikesPost")
  comments   Comment[]
  media      PostMedia[]
  savedBy    User[]      @relation("UserSavedPosts")
  repostOfId String?
  repostOf   Post?       @relation("Reposts", fields: [repostOfId], references: [id], onDelete: Cascade)
  reposts    Post[]      @relation("Reposts")
}

model PostMedia {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  url       String
  type      String   // PHOTO or VIDEO
  createdAt DateTime @default(now())
}

model Email {
  id           String   @id @default(uuid())
  senderId     String
  sender       User     @relation("SentEmails", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId   String
  receiver     User     @relation("ReceivedEmails", fields: [receiverId], references: [id], onDelete: Cascade)
  subject      String
  message      String
  attachment   String?
  createdAt    DateTime @default(now())
  isRead       Boolean  @default(false)
  isSupport    Boolean  @default(false)
}

model SupportTicket {
  id           String          @id @default(uuid())
  ticketNumber String          @unique // e.g. LMS-2034
  studentId    String
  student      User            @relation("StudentTickets", fields: [studentId], references: [id], onDelete: Cascade)
  subject      String
  description  String
  category     String          @default("Technical Issues")
  priority     String          @default("Medium")
  status       String          @default("Open")
  attachment   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  assignedToId String?
  assignedTo   User?           @relation("AssignedTickets", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages     TicketMessage[]
}

model TicketMessage {
  id         String        @id @default(uuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  message    String
  attachment String?
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now())
}

model KBArticle {
  id          String   @id @default(uuid())
  title       String
  category    String
  description String
  content     String
  imageUrl    String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model WorkspaceTeam {
  id          String             @id @default(uuid())
  name        String
  description String
  status      String             @default("Active")
  createdAt   DateTime           @default(now())
  members     TeamMember[]
  projects    WorkspaceProject[]
}

model TeamMember {
  id        String        @id @default(uuid())
  teamId    String
  team      WorkspaceTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleName  String        @default("Member")
  status    String        @default("Accepted") // Pending, Accepted, Rejected
  createdAt DateTime      @default(now())

  @@unique([teamId, userId])
}

model WorkspaceProject {
  id                   String         @id @default(uuid())
  name                 String
  description          String
  logoUrl              String?
  category             String
  technologies         String
  status               String         @default("Planning")
  completionPercentage Int            @default(0)
  keyFeatures          String
  gallery              String?
  liveDemoUrl          String?
  githubUrl            String?
  docsUrl              String?
  demoVideoUrl         String?
  submittedFiles       String?
  teamId               String?
  team                 WorkspaceTeam? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  ownerId              String
  owner                User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt            DateTime       @default(now())
}

model Internship {
  id                 String                  @id @default(uuid())
  companyName        String
  companyLogo        String?
  companyDescription String
  industry           String
  website            String?
  title              String
  category           String
  duration           String
  mode               String                  @default("Remote")
  skills             String
  responsibilities   String
  requirements       String
  benefits           String?
  deadline           DateTime
  createdAt          DateTime                @default(now())
  applications       InternshipApplication[]
}

model InternshipApplication {
  id           String     @id @default(uuid())
  internshipId String
  internship   Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  studentId    String
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       String     @default("Applied") // Applied, Under Review, Interview, Accepted, Rejected
  appliedAt    DateTime   @default(now())
  
  // Applicant Info
  fullName     String     @default("")
  email        String     @default("")
  university   String     @default("")
  grade        String     @default("")
  yearInUniversity String @default("")
  resumeUrl    String     @default("")
  portfolio    String?

  @@unique([internshipId, studentId])
}
